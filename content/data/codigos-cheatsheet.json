    "kind": "cards",
    "items": [
      {
        "title": "Operatividad (Por SAMUR-2)",
        "lines": [
          "Clave 11, Clave 0, con TETRA 12___ y 12___, Móvil ___.",
          "Nos dirigimos al preventivo de ______ / retén / otro.",
          "Estaremos ubicados en __.",
          "A la escucha en canal SAMUR __."
        ]
      },
      {
        "title": "Solicitud Clave 16 de SVA (Por SAMUR-1)",
        "lines": [
          "Solicito Clave 16 de SVA para sexo, edad y motivo principal.",
          "Añadir FR, SpO2, FC, TA y nivel de conciencia.",
          "Si es trauma, indicar mecanismo lesional y lesiones principales.",
          "Añadir otra información relevante."
        ]
      },
      {
        "title": "Paso a Clave 0 (Por SAMUR-3)",
        "lines": [
          "En el lugar (Clave 3): Clave 0 en el punto.",
          "Se hace cargo SAMUR XXX / 091 / 092 / SAMUR Social / otro.",
          "Código final _.__ y código de valoración _.__.__.",
          "En hospital (Clave 5): Clave 0 en el hospital ______."
        ]
      },
      {
        "title": "Finalización del servicio",
        "lines": [
          "En el lugar: Solicitamos Clave 14 por finalización del evento.",
          "Añadir sin asistencias o con __ asistencias.",
          "Al llegar a B0: Clave 12."
        ]
      },
      {
        "title": "Estructura de un mensaje de aviso",
        "lines": [
          "8___ / _.__ / Lugar / __ / XXXXXX / Información / HH:MM / H__",
          "Incluye unidad, código inicial, ubicación, distrito, número de informe, observaciones, hora y hospital de referencia si aplica."
        ]
      }
    ]
  },
