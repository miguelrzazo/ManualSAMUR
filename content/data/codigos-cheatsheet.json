  {
    "key": "tetra",
    "title": "Utilidades TETRA Motorola",
    "kind": "cards",
    "items": [
      {
        "title": "Activar localización (GPS)",
        "lines": ["Menú → Ubicación → Interfaz → Activar → Selecc."]
      },
      {
        "title": "Pasar a Metro",
        "lines": [
          "Paso 1: Menú → Redes → Selec. Red → Cualquier red → Selecc.",
          "Paso 2: Pulsación prolongada del botón verde lateral izquierdo.",
          "Debe aparecer METRO / SAMUR MTR si hay cobertura de la red TETRA de Metro."
        ]
      },
      {
        "title": "Bloquear o desbloquear teclado",
        "lines": ["Tecla menú + *"]
      },
      {
        "title": "Cambiar modo Red (TMO) ↔ Directo (DMO)",
        "lines": ["Pulsación prolongada # o *"]
      },
      {
        "title": "Llamada privada o cerrada",
        "lines": [
          "Recepción: cuando suena la llamada, pulsar PTT para descolgar.",
          "Emisión: en pantalla principal teclear el número y después pulsar PTT."
        ]
      }
    ]
  },
