{
  "name": "manual-samur",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run sync:docs-public && next dev",
    "generate:llms": "node --experimental-strip-types scripts/generate-llms.ts",
    "sync:docs-public": "node --experimental-strip-types scripts/sync-public-docs.ts",
    "extract:pdf": "node --experimental-strip-types scripts/extract-pdf-text.ts",
    "discover:wiki": "node --experimental-strip-types scripts/discover-wiki-pages.ts",
    "sync:full": "npm run sync:manualsamur && npm run sync:docs-public && npm run extract:pdf && npm run generate:llms",
    "build": "npm run sync:docs-public && node --experimental-strip-types scripts/generate-llms.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "sync:manualsamur": "node --experimental-strip-types scripts/sync-manualsamur.ts --all",
    "sync:vademecum": "node --experimental-strip-types scripts/scrape-vademecum.ts",
    "migrate:subfolders": "node --experimental-strip-types scripts/migrate-to-subfolders.ts",
    "audit:manual-relations": "node --experimental-strip-types scripts/audit-manual-relations.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor/core": "^8.3.2",
    "@capacitor/ios": "^8.3.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@types/cheerio": "^0.22.35",
    "@types/turndown": "^5.0.6",
    "@xyflow/react": "^12.10.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "mermaid": "^11.14.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.7.284",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "reactflow": "^11.11.4",
    "rehype-slug": "^6.0.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3"
  }
}
